    {
        "id": "6aa10cdabcc3eb61",
        "type": "function",
        "z": "ad1a57699d3b0f06",
        "name": "validate threshold",
        "func": "let raw = msg.payload ? msg.payload.threshold : undefined;\n\nif (raw === undefined || raw === null || raw === \"\") {\n    const errMsg = {\n        ...msg,\n        statusCode: 400,\n        headers: { \"Content-Type\": \"application/json\" },\n        payload: { ok: false, error: \"Inserisci un numero valido\" }\n    };\n    return [null, null, errMsg];\n}\n\nif (typeof raw === \"string\") {\n    raw = raw.trim();\n    if (raw === \"\") {\n        const errMsg = {\n            ...msg,\n            statusCode: 400,\n            headers: { \"Content-Type\": \"application/json\" },\n            payload: { ok: false, error: \"Inserisci un numero valido\" }\n        };\n        return [null, null, errMsg];\n    }\n}\n\nconst value = Number(raw);\n\nif (!Number.isFinite(value)) {\n    const errMsg = {\n        ...msg,\n        statusCode: 400,\n        headers: { \"Content-Type\": \"application/json\" },\n        payload: { ok: false, error: \"Inserisci un numero valido\" }\n    };\n    return [null, null, errMsg];\n}\n\nconst dbMsg = {\n    ...msg,\n    threshold: value,\n    payload: { threshold: value }\n};\n\nconst okMsg = {\n    ...msg,\n    threshold: value,\n    statusCode: 200,\n    headers: { \"Content-Type\": \"application/json\" },\n    payload: { ok: true, threshold: value }\n};\n\nreturn [dbMsg, okMsg, null];",
