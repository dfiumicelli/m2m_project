    {
        "id": "e715e3d873f7dbba",
        "type": "function",
        "z": "ad1a57699d3b0f06",
        "name": "Valuta switch live",
        "func": "const temp = Number(msg.payload.temperature);\nif (!Number.isFinite(temp)) {\n    node.status({ fill: 'red', shape: 'ring', text: 'temperature non valida' });\n    return null;\n}\n\nconst soglia = Number(flow.get('threshold'));\nif (!Number.isFinite(soglia)) {\n    node.status({ fill: 'yellow', shape: 'ring', text: 'soglia non impostata' });\n    return null;\n}\n\nconst switchCount = Number(flow.get('switchCount') || 5);\nif (!Number.isFinite(switchCount) || switchCount < 1) {\n    node.status({ fill: 'yellow', shape: 'ring', text: 'switchCount non valido' });\n    return null;\n}\n\nlet stato = String(flow.get('tasmotaState') || 'UNKNOWN').toUpperCase();\nlet sopra = context.get('sopraCount') || 0;\nlet sotto = context.get('sottoCount') || 0;\n\nflow.set('ultimaTemperatura', temp);\nflow.set('ultimaSoglia', soglia);\nflow.set('ultimoSwitchCount', switchCount);\n\nif (temp > soglia) {\n    sopra += 1;\n    sotto = 0;\n} else if (temp < soglia) {\n    sotto += 1;\n    sopra = 0;\n} else {\n    return null;\n}\n\ncontext.set('sopraCount', sopra);\ncontext.set('sottoCount', sotto);\n\nnode.status({\n    fill: temp > soglia ? 'red' : 'blue',\n    shape: 'dot',\n    text: `T=${temp} S=${soglia} su=${sopra} giu=${sotto} n=${switchCount} stato=${stato}`\n});\n\nif (sopra >= switchCount && stato !== 'ON') {\n    flow.set('tasmotaState', 'ON');\n    context.set('sopraCount', 0);\n    return {\n        topic: 'cmnd/pdc/POWER',\n        payload: 'ON'\n    };\n}\n\nif (sotto >= switchCount && stato !== 'OFF') {\n    flow.set('tasmotaState', 'OFF');\n    context.set('sottoCount', 0);\n    return {\n        topic: 'cmnd/pdc/POWER',\n        payload: 'OFF'\n    };\n}\n\nreturn null;",
