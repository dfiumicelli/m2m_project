    {
        "id": "561bf7f3ea055d4f",
        "type": "function",
        "z": "ad1a57699d3b0f06",
        "name": "Tasmota state -> Influx",
        "func": "const stato = String(msg.payload || '').trim().toUpperCase();\nif (stato !== 'ON' && stato !== 'OFF') return null;\n\nconst last = context.get('lastLoggedState');\nif (last === stato) return null;\ncontext.set('lastLoggedState', stato);\n\nmsg.payload = {\n    'on/off': stato === 'ON' ? 1 : 0\n};\nreturn msg;",
